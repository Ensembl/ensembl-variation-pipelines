nextflow_process {

    name "Test Process BED_TO_BIGBED"
    script "../main.nf"
    process "BED_TO_BIGBED"

    test("bed_to_bigbed") {

        when {
            process {
                """
				// use moduleDir for consistent snapshot
                tmp_dir = "${moduleDir}/tests/temp"
                file(tmp_dir).mkdirs()
                
				meta = [:]
                meta["source"] = "test"
				meta["chrom_sizes_file"] = file("${projectDir}/tests/testdata/homo_sapiens_GRCh38.chrom.sizes")
                meta["multiple_source"] = false
				meta["genome_tracks_outdir"] = tmp_dir

				input[0] = tuple(meta, file("${moduleDir}/tests/testdata/short_variants.bed"))
				input[1] = file("${projectDir}/assets/short_variant_bedfields.json")
                """
            }
        }

        then {
            assert process.success 
            assert snapshot(process.out).match()
            
            // the output is generated at the genome tracks dir
			// assert for single source we symlink the focus track
            def tmp_dir = "${moduleDir}/tests/temp"
			assert file(tmp_dir + "/variant-test-details.bb").exists()
			assert file(tmp_dir + "/variant-details.bb").exists()
			assert file(tmp_dir + "/variant-details.bb").getCanonicalPath() == 
				(projectDir + "/modules/local/bed_to_bigbed/tests/temp/variant-test-details.bb")
		}
    }
}
