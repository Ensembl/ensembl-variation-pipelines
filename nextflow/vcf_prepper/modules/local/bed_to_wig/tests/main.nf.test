nextflow_process {

    name "Test Process BED_TO_WIG"
    script "../main.nf"
    process "BED_TO_WIG"

    test("bed_to_wig") {

        when {
            process {
                """
				meta = [:]
                meta["source"] = "test"

				input[0] = tuple(meta, file("${moduleDir}/tests/testdata/short_variants.bed"))
                """
            }
        }

        then {
            assert process.success 
            assert snapshot(process.out).match()
		}
    }
}
