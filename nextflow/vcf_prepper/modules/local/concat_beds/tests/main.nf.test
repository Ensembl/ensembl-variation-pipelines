nextflow_process {

    name "Test Process CONCAT_BEDS"
    script "../main.nf"
    process "CONCAT_BEDS"

    test("concat_beds") {

        when {
            process {
                """
                genoem_meta = [:]
                file_meta = [:]
				file_meta["source"] = "test"
                
				input[0] = tuple(genoem_meta, file_meta, file("${moduleDir}/tests/testdata/test_bed*.bed"))
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
            
            // assert the content of the output file
            def output_file = file(process.out.get(0).get(0).get(2))
            def lines = output_file.readLines()
            assert lines.size() == 5

			// asssert temp and all.bed files are deleted
			assert ! file(workDir + "/all.bed").exists()
			assert ! file(workDir + "/tmp").exists()
		}
    }
}
