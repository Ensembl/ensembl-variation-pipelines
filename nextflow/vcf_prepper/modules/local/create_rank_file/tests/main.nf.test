nextflow_process {

    name "Test process CREATE_RANK_FILE"
    script "../main.nf"
    process "CREATE_RANK_FILE"

    test("create_rank_file") {

        when {
            process {
                """
                // use moduleDir for consistent snapshot
                tmp_dir = "${moduleDir}/tests/temp"
                file(tmp_dir).mkdirs()

                input[0] = tmp_dir + "/consequence_rank.json"
                """
            }
        }

        then {
            assert process.success

            def rank_file = "${moduleDir}/tests/temp/consequence_rank.json"
            assert file(rank_file).exists()

			// check some values
            assert path(rank_file).json.missense_variant == "13"
            assert path(rank_file).json.stop_lost == "6"
            assert path(rank_file).json.upstream_gene_variant == "32"
            assert path(rank_file).json.frameshift_variant == "5"
			assert path(rank_file).json.splice_donor_5th_base_variant == "15"
        }
    }
}