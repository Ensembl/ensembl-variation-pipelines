nextflow_process {

    name "Test process FORMAT_VCF"
    script "../main.nf"
    process "FORMAT_VCF"

    test("remove criteria - all") {

        when {
            params {
                remove_nonunique_ids = 1
                remove_patch_regions = 1
            }
            process {
                """
                genome_meta = [
                        'synonym_file':"${projectDir}/tests/testdata/homo_sapiens_grch38.synonyms"
                    ]
                file_meta = [
                        'source':'dbSNP',
                        'sources_meta_file':"${projectDir}/assets/sources_meta.json"
                    ]
                vcf = "${moduleTestDir}/testdata/test_format_vcf.vcf.gz"
                vcf_index = "${moduleTestDir}/testdata/test_format_vcf.vcf.gz.tbi"

                input[0] = tuple(
                        genome_meta, 
                        file_meta,
                        file(vcf),
                        file(vcf_index)
                    )
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()

            // following is duplicate of snapshot match but for readability purpose
            // should be used to check if snapshot is invalid
            def lines = path(process.out.get("0").get(0).get(1)).linesGzip[0..-1]
            assert lines.size() == 13
            assert lines[0].equals('##fileformat=VCFv4.2')
            assert lines[1].equals('##FILTER=<ID=PASS,Description="All filters passed">')
            assert lines[2].equals('##INFO=<ID=SOURCE,Number=1,Type=String,Description="Source of the variation data">')
            assert lines[3].equals('##INFO=<ID=END,Number=1,Type=Integer,Description="End position of the variant described in this record">')
            assert lines[4].equals('##INFO=<ID=SVLEN,Number=.,Type=String,Description="Difference in length between REF and ALT alleles">')
            assert lines[5].equals('##INFO=<ID=NODEID,Number=1,Type=String,Description="Identifier of the nodes this variant belong to">')
            assert lines[6].equals('##contig=<ID=1>')
            assert lines[7].equals('##contig=<ID=CHR_HSCHR1_3_CTG31>')
            assert lines[8].equals('##contig=<ID=Y>')
            assert lines[9].equals('##source="dbSNP" description="NCBI db of human variants" url="https://www.ncbi.nlm.nih.gov/snp/" version="157" accession_url="https://www.ncbi.nlm.nih.gov/snp/"')
            assert lines[10].equals('#CHROM\tPOS\tID\tREF\tALT\tQUAL\tFILTER\tINFO')
            assert lines[11].equals('1\t925952\t1019397\tG\tA\t.\t.\tSOURCE=dbSNP')
            assert lines[12].equals('Y\t2787033\t652674\tAG\tA\t.\t.\tSOURCE=dbSNP')
        }
    }

    test("remove criteria - non-unique ids") {

        when {
            params {
                remove_nonunique_ids = 1
                remove_patch_regions = 0
            }
            process {
                """
                genome_meta = [
                        'synonym_file':"${projectDir}/tests/testdata/homo_sapiens_grch38.synonyms"
                    ]
                file_meta = [
                        'source':'dbSNP',
                        'sources_meta_file':"${projectDir}/assets/sources_meta.json"
                    ]
                vcf = "${moduleTestDir}/testdata/test_format_vcf.vcf.gz"
                vcf_index = "${moduleTestDir}/testdata/test_format_vcf.vcf.gz.tbi"

                input[0] = tuple(
                        genome_meta, 
                        file_meta,
                        file(vcf),
                        file(vcf_index)
                    )
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()

            // following is duplicate of snapshot match but for readability purpose
            // should be used to check if snapshot is invalid
            def lines = path(process.out.get("0").get(0).get(1)).linesGzip[0..-1]
            assert lines.size() == 14
            assert lines[0].equals('##fileformat=VCFv4.2')
            assert lines[1].equals('##FILTER=<ID=PASS,Description="All filters passed">')
            assert lines[2].equals('##INFO=<ID=SOURCE,Number=1,Type=String,Description="Source of the variation data">')
            assert lines[3].equals('##INFO=<ID=END,Number=1,Type=Integer,Description="End position of the variant described in this record">')
            assert lines[4].equals('##INFO=<ID=SVLEN,Number=.,Type=String,Description="Difference in length between REF and ALT alleles">')
            assert lines[5].equals('##INFO=<ID=NODEID,Number=1,Type=String,Description="Identifier of the nodes this variant belong to">')
            assert lines[6].equals('##contig=<ID=1>')
            assert lines[7].equals('##contig=<ID=CHR_HSCHR1_3_CTG31>')
            assert lines[8].equals('##contig=<ID=Y>')
            assert lines[9].equals('##source="dbSNP" description="NCBI db of human variants" url="https://www.ncbi.nlm.nih.gov/snp/" version="157" accession_url="https://www.ncbi.nlm.nih.gov/snp/"')
            assert lines[10].equals('#CHROM\tPOS\tID\tREF\tALT\tQUAL\tFILTER\tINFO')
            assert lines[11].equals('1\t925952\t1019397\tG\tA\t.\t.\tSOURCE=dbSNP')
            assert lines[12].equals('CHR_HSCHR1_3_CTG31\t42\trs1656322366\tT\tG\t.\t.\tSOURCE=dbSNP')
            assert lines[13].equals('Y\t2787033\t652674\tAG\tA\t.\t.\tSOURCE=dbSNP')
        }
    }

