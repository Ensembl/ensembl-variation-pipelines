nextflow_process {

    name "Test process GENERATE_CHROM_SIZES"
    script "../main.nf"
    process "GENERATE_CHROM_SIZES"

    test("chrom_sizes") {

        when {
            process {
                """

                input[0] = [
                    'genome':'homo_sapiens_grch38', 
                    'species':'homo_sapiens', 
                    'assembly':'GRCh38',
                    'chrom_sizes_file':"${workDir}/homo_sapiens_grch38.chrom.sizes"
                ]
                input[1] = 110
                input[2] = "${projectDir}/tests/testdata/test_db.ini"
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()

            // genome_meta should be same as input
            assert process.out.get(0).get(0).get(0) == [
                    'genome':'homo_sapiens_grch38', 
                    'species':'homo_sapiens', 
                    'assembly':'GRCh38',
                    'chrom_sizes_file':"${workDir}/homo_sapiens_grch38.chrom.sizes"
                ]
            assert path("${workDir}/homo_sapiens_grch38.chrom.sizes").md5 == "77e059be395da32b566fe37a13439427"
        }
    }
}