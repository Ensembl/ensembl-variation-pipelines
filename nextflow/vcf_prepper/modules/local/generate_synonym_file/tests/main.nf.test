nextflow_process {

    name "Test process GENERATE_SYNONYM_FILE"
    script "../main.nf"
    process "GENERATE_SYNONYM_FILE"

    test("synonym_file") {

        when {
            process {
                """

                input[0] = [
                    'genome':'homo_sapiens_grch38', 
                    'species':'homo_sapiens', 
                    'assembly':'GRCh38',
                    'synonym_file':"${workDir}/homo_sapiens_grch38.synonyms"
                ]
                input[1] = 110
                input[2] = "${projectDir}/tests/testdata/test_db.ini"
                """
            }
        }

        then {
            
            assert process.success
            assert snapshot(process.out).match()

            // genome_meta should be same as input
            assert process.out.get(0).get(0).get(0) == [
                    'genome':'homo_sapiens_grch38', 
                    'species':'homo_sapiens', 
                    'assembly':'GRCh38',
                    'synonym_file':"${workDir}/homo_sapiens_grch38.synonyms"
                ]
            assert path("${workDir}/homo_sapiens_grch38.synonyms").md5 == "2e6bf0348c272e8d6c9829e4cb50d585"
        }
    }
}