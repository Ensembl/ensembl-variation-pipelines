nextflow_process {

    name "Test process SPLIT_VCF_CHR"
    script "../main.nf"
    process "SPLIT_VCF_CHR"

	test("split_vcf_chr") {

        when {
            process {
                """                
                vcf = file("${moduleDir}/tests/testdata/test.vcf.gz")
                vcf_index = file("${moduleDir}/tests/testdata/test.vcf.gz.csi")
				chr_file = "1.chrom"
				file(chr_file).mkdirs()

                input[0] = tuple([:], vcf, vcf_index, file(chr_file))
                """
            }
        }

        then {
            assert process.success

            assert file(process.out.get(0).get(0).get(1)).name == "split.1.vcf.gz"
            assert path(process.out.get(0).get(0).get(1)).vcf.chromosomes == ['1'] as Set
        }
    }
}