nextflow_process {

    name "Test Process STAGE_FILE"
    script "../main.nf"
    process "STAGE_FILE"

    test('remote file - tbi index') {

        when {
            process {
                """
                genome_meta = [:]
                file_meta = [:]
                file_meta["file_type"] = "remote"
                file = "https://ftp.ncbi.nlm.nih.gov/pub/dbVar/data/Homo_sapiens/by_study/vcf/nstd14.GRCh38.variant_call.vcf.gz"

                input[0] = tuple(genome_meta, file_meta, file)
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }

    test('remote file - csi index') {

        when {
            process {
                """
                genome_meta = [:]
                file_meta = [:]
                file_meta["file_type"] = "remote"
                file = "https://ftp.ebi.ac.uk/pub/databases/eva/rs_releases/release_6/by_species/triticum_aestivum/GCA_900519105.1/4565_GCA_900519105.1_merged_ids.vcf.gz"

                input[0] = tuple(genome_meta, file_meta, file)
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }

        test('local file') {

        when {
            process {
                """
                genome_meta = [:]
                file_meta = [:]
                file_meta["file_type"] = "local"
                file = "${projectDir}/assets/examples/test.vcf.gz"

                input[0] = tuple(genome_meta, file_meta, file)
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }

}