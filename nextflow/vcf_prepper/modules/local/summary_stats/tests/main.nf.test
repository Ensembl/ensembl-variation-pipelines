nextflow_process {

    name "Test process SUMMARY_STATS"
    script "../main.nf"
    process "SUMMARY_STATS"

	test("summary_stats - population.json is 'NONE'") {

        when {
            process {
                """                
                genome_meta = [
                        'species':'homo_sapiens',
                        'assembly':'GRCh38'
                    ]
				file_meta = [:]
                vcf = file("${moduleDir}/tests/testdata/test.vcf_VEP.vcf.gz")
                vcf_index = file("${moduleDir}/tests/testdata/test.vcf_VEP.vcf.gz.csi")

                input[0] = tuple(genome_meta, file_meta, vcf, vcf_index)
				input[1] = "NONE"
                """
            }
        }

        then {
            assert process.success
			assert snapshot(process.out).match()

            def out_vcf = path(process.out.get(0).get(0).get(2)).vcf

            // file content ok
            assert out_vcf.variants.size() == 1
            assert out_vcf.variantsMD5 == 'd02d526bfcb5ffeae9f836987211fd6a'

            // header has summary stats tag
            assert out_vcf.header.hasInfoLine('NTCSQ')
            assert out_vcf.header.hasInfoLine('NRCSQ')
            assert out_vcf.header.hasInfoLine('NGENE')
            assert out_vcf.header.hasInfoLine('NVPHN')
            assert out_vcf.header.hasInfoLine('NGPHN')
            assert out_vcf.header.hasInfoLine('NCITE')
            assert out_vcf.header.hasInfoLine('RAF')

            // corrent summary stats value
            assert out_vcf.getInfoTag('NTCSQ', "1", 230710048) == '12'
            assert out_vcf.getInfoTag('NGENE', "1", 230710048) == '1'
		}
    }

    test("summary_stats - no RAF") {

        when {
            process {
                """                
                genome_meta = [
                        'species':'homo_sapiens',
                        'assembly':'GRCh38'
                    ]
				file_meta = [:]
                vcf = file("${moduleDir}/tests/testdata/test.vcf_VEP.vcf.gz")
                vcf_index = file("${moduleDir}/tests/testdata/test.vcf_VEP.vcf.gz.csi")

                input[0] = tuple(genome_meta, file_meta, vcf, vcf_index)
				input[1] = "${projectDir}/assets/population_data.json"
                """
            }
        }

        then {
            assert process.failed
			assert process.errorReport.contains("Unable to retrieve CSQ field index for RAF")
		}
    }
}