nextflow_process {

    name "Test process PROCESS_CACHE_CONFIG"
    script "../main.nf"
    process "PROCESS_CACHE_CONFIG"
    config "modules/local/vep_config/cache/tests/nextflow.config"

    test("cache_dir - inactive") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = ['active':false]
                input[2] = 110
                input[3] = 'NONE'
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }
    
    test("cache_dir - no cache") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']
                input[1] = ['dir':"${moduleDir}/tests"]
                input[2] = 110
                input[3] = 'NONE'
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("FileNotFoundError")
        }
    }

    test("cache_dir - proper") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']
                input[1] = ['dir':"${moduleDir}/tests/testdata"]
                input[2] = 110
                input[3] = "${projectDir}/tests/testdata/test_db.ini"
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()

            // genome_meta does not change
            assert process.out.get(0).get(0).get(0) == ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']
        }
    }

    test("factory - no ini file") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = [:]
                input[2] = 110
                input[3] = 'NONE'
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("FileNotFoundError")
        }
    }

    test("factory - old ftp") {

        when {
            process {
                """
                // use moduleDir for consistent snapshot
                tmp_dir = "${moduleDir}/tests/temp"
                file(tmp_dir).mkdirs()

                input[0] = [
                        'genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 
                        'species':'homo_sapiens', 
                        'assembly':'GRCh38',
                        'genome_temp_dir':tmp_dir
                    ]
                input[1] = [:]
                input[2] = 110
                input[3] = "${projectDir}/tests/testdata/test_db.ini"
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }
}