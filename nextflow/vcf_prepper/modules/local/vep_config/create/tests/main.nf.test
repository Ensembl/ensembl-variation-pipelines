nextflow_process {

    name "Test process CREATE_VEP_CONFIG"
    script "../main.nf"
    process "CREATE_VEP_CONFIG"

    test("cache inactive") {
        setup {
            run("PROCESS_DEFAULT_OPTIONS_CONFIG") {
                script "../../default_options"

                process {
                    """
                    input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']
                    input[1] = [force_overwrite:1, fork:2, vcf:1, spdi:1, variant_class:1, protein:1, transcript_version:1, gencode_promoter:1, offline:1]
                    """
                }
            }

            run("PROCESS_FASTA_CONFIG") {
                script "../../fasta"

                // not using factory because my local setting has issue with HTSlib
                process {
                    """
                    input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']
                    input[1] = ['file':"${projectDir}/modules/local/vep_config/fasta/tests/testdata/unmasked.fa.gz"]
                    input[2] = 110
                    input[3] = 'NONE'
                    """
                }
            }

            run("PROCESS_GFF_CONFIG") {
                script "../../gff"

                process {
                    """
                    input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']
                    input[1] = ['file':"${projectDir}/modules/local/vep_config/gff/tests/testdata/genes.gff3.gz"]
                    input[2] = 'NONE'
                    """
                }
            }

            run("PROCESS_CACHE_CONFIG") {
                script "../../cache"

                process {
                    """
                    input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']
                    input[1] = ['active':false]
                    input[2] = 110
                    input[3] = "${projectDir}/tests/testdata/test_db.ini"
                    """
                }
            }

            run("PROCESS_PLUGINS_CONFIG") {
                script "../../plugins"

                process {
                    """
                    input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']
                    input[1] = [conf:[[name:'CADD', keyed:true], [name:'SpliceAI', keyed:true]]]
                    input[2] = 110
                    input[3] = "${projectDir}"
                    """
                }
            }

            run("PROCESS_CUSTOM_ANNOTATIONS_CONFIG") {
                script "../../custom_annotations"

                process {
                    """
                    input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']
                    input[1] = [:]
                    input[2] = 110
                    input[3] = "${projectDir}/assets/population_data.json"
                    input[4] = true
                    """
                }
            }
        }
        when {
            process {
                """
                input[0] = Channel.of(['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38'])
                    .combine(PROCESS_DEFAULT_OPTIONS_CONFIG.out, by:0)
                    .combine(PROCESS_FASTA_CONFIG.out, by:0)
                    .combine(PROCESS_GFF_CONFIG.out, by:0)
                    .combine(PROCESS_CACHE_CONFIG.out, by:0)
                    .combine(PROCESS_PLUGINS_CONFIG.out, by:0)
                    .combine(PROCESS_CUSTOM_ANNOTATIONS_CONFIG.out, by:0)
                """
            }
        }

        then {
            assert process.success

            // genome_meta does not change
            assert process.out.get(0).get(0).get(0) == [
                'genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 
                'species':'homo_sapiens', 
                'assembly':'GRCh38'
            ]

            // cannot do snapshot match as cache dir path may vary 
            def file_content = path(process.out.get(0).get(0).get(1)).text
            assert file_content.contains("force_overwrite\t1")
            assert file_content.contains("fork\t2")
            assert file_content.contains("vcf\t1")
            assert file_content.contains("spdi\t1")
            assert file_content.contains("variant_class\t1")
            assert file_content.contains("protein\t1")
            assert file_content.contains("transcript_version\t1")
            assert file_content.contains("gencode_promoter\t1")
            assert file_content.contains("offline\t1")
            assert file_content.contains("fasta\t${projectDir}/modules/local/vep_config/fasta/tests/testdata/unmasked.fa.gz")
            assert file_content.contains("gff\t${projectDir}/modules/local/vep_config/gff/tests/testdata/genes.gff3.gz")
            assert file_content.contains("plugin\tCADD,snv=${projectDir}/modules/local/vep_config/plugins/tests/testdata/grch38/e113/vep/plugin_data/CADD_GRCh38_1.7_whole_genome_SNVs.tsv.gz,indels=${projectDir}/modules/local/vep_config/plugins/tests/testdata/grch38/e113/vep/plugin_data/CADD_GRCh38_1.7_InDels.tsv.gz")
            assert file_content.contains("plugin\tSpliceAI,snv=${projectDir}/modules/local/vep_config/plugins/tests/testdata/grch38/e113/vep/plugin_data/spliceai_scores.masked.snv.hg38.vcf.gz,indel=${projectDir}/modules/local/vep_config/plugins/tests/testdata/grch38/e113/vep/plugin_data/spliceai_scores.masked.indel.hg38.vcf.gz")
        }
    }
}