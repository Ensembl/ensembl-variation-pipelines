nextflow_process {

    name "Test process CREATE_VEP_CONFIG"
    script "../main.nf"
    process "CREATE_VEP_CONFIG"

    test("no conf") {
        setup {
            run("DEFAULT_OPTIONS") {
                script "../../default_options"
                process {
                    """
                    input[0] = [genome_uuid:"2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb"]
                    input[1] = [force_overwrite:1, fork:2, vcf:1, spdi:1, variant_class:1, protein:1, transcript_version:1, gencode_promoter:1, offline:1]
                    """
                }
            }

            run("FASTA") {
                script "../../fasta"
                process {
                    """
                    input[0] = [genome_uuid:"2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb"]
                    input[1] = [force_overwrite:1, fork:2, vcf:1, spdi:1, variant_class:1, protein:1, transcript_version:1, gencode_promoter:1, offline:1]
                    """
                }
            }

            run("DEFAULT_OPTIONS") {
                script "../../default_options"
                process {
                    """
                    input[0] = [genome_uuid:"2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb"]
                    input[1] = [force_overwrite:1, fork:2, vcf:1, spdi:1, variant_class:1, protein:1, transcript_version:1, gencode_promoter:1, offline:1]
                    """
                }
            }

            run("DEFAULT_OPTIONS") {
                script "../../default_options"
                process {
                    """
                    input[0] = [genome_uuid:"2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb"]
                    input[1] = [force_overwrite:1, fork:2, vcf:1, spdi:1, variant_class:1, protein:1, transcript_version:1, gencode_promoter:1, offline:1]
                    """
                }
            }

            run("DEFAULT_OPTIONS") {
                script "../../default_options"
                process {
                    """
                    input[0] = [genome_uuid:"2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb"]
                    input[1] = [force_overwrite:1, fork:2, vcf:1, spdi:1, variant_class:1, protein:1, transcript_version:1, gencode_promoter:1, offline:1]
                    """
                }
            }
        }
        when {
            process {
                """
                input[0] = tuple(
                        ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']

                    )
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("FileNotFoundError")
        }
    }
}