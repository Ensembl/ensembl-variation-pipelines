nextflow_process {

    name "Test process PROCESS_FASTA_CONFIG"
    script "../main.nf"
    process "PROCESS_FASTA_CONFIG"

    test("fasta_file - gzipped") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = ['file':"${moduleDir}/tests/testdata/unmasked_gzip.fa.gz"]
                input[2] = 110
                input[3] = 'NONE'
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("either not bgzipped or missing index")
        }
    }

    test("fasta_file - no index") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = ['file':"${moduleDir}/tests/testdata/unmasked_bgzip_noindex.fa.gz"]
                input[2] = 110
                input[3] = 'NONE'
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("either not bgzipped or missing index")
        }
    }

    test("fasta_file - proper") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = ['file':"${moduleDir}/tests/testdata/unmasked.fa.gz"]
                input[2] = 110
                input[3] = 'NONE'
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }

    test("fasta_dir - no file") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = ['dir':"${moduleDir}/tests"]
                input[2] = 110
                input[3] = 'NONE'
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("FileNotFoundError")
        }
    }

    test("fasta_dir - current factory") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = ['dir':"${moduleDir}/tests/testdata"]
                input[2] = 110
                input[3] = 'NONE'
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }

    test("fasta_dir - old factory") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']
                input[1] = ['dir':"${moduleDir}/tests/testdata", 'factory':'old']
                input[2] = 110
                input[3] = 'NONE'
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()

            // genome_meta does not change
            assert process.out.get(0).get(0).get(0) == ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']
        }
    }

    test("factory - no ini file") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = [:]
                input[2] = 110
                input[3] = 'NONE'
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("FileNotFoundError")
        }
    }

    test("factory - new ftp") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = [:]
                input[2] = 110
                input[3] = "${projectDir}/tests/testdata/test_db.ini"
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()

            // genome_meta does not change
            assert process.out.get(0).get(0).get(0) == ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
        }
    }

    test("factory - old ftp") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']
                input[1] = ['factory':'old']
                input[2] = 110
                input[3] = "${projectDir}/tests/testdata/test_db.ini"
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()

            // genome_meta does not change
            assert process.out.get(0).get(0).get(0) == ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
        }
    }
}