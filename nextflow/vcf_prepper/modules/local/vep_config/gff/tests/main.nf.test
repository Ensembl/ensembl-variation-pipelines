nextflow_process {

    name "Test process PROCESS_GFF_CONFIG"
    script "../main.nf"
    process "PROCESS_GFF_CONFIG"

    test("gff_file - inactive") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = ['active':false]
                input[2] = 'NONE'
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }

    test("gff_file - gzipped") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = ['file':"${moduleDir}/tests/testdata/genes_gzip.gff3.gz"]
                input[2] = 'NONE'
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("either not bgzipped or missing tabix index")
        }
    }

    test("gff_file - no index") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = ['file':"${moduleDir}/tests/testdata/genes_bgzip_noindex.gff3.gz"]
                input[2] = 'NONE'
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("either not bgzipped or missing tabix index")
        }
    }

    test("gff_file - proper") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = ['file':"${moduleDir}/tests/testdata/genes.gff3.gz"]
                input[2] = 'NONE'
                """
            }
        }

        then {
            assert process.success   
            
            // genome_meta does not change
            assert process.out.get(0).get(0).get(0) == [
                'genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb'
            ]

            // cannot do snapshot match as cache dir path may vary 
            def file_content = path(process.out.get(0).get(0).get(1)).text
            assert file_content.contains("gff\t${moduleDir}/tests/testdata/genes.gff3.gz")        
        }
    }

    test("gff_dir - no file") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = ['dir':"${moduleDir}/tests"]
                input[2] = 'NONE'
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("FileNotFoundError")
        }
    }

    test("gff_dir - proper") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = ['dir':"${moduleDir}/tests/testdata"]
                input[2] = 'NONE'
                """
            }
        }

        then {
            assert process.success

            // genome_meta does not change
            assert process.out.get(0).get(0).get(0) == [
                'genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb'
            ]

            // cannot do snapshot match as cache dir path may vary 
            def file_content = path(process.out.get(0).get(0).get(1)).text
            assert file_content.contains("gff\t${moduleDir}/tests/testdata/genes.gff3.gz")
        }
    }

    test("factory - no ini file") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = [:]
                input[2] = 'NONE'
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("FileNotFoundError")
        }
    }

    test("factory - new ftp") {

        when {
            process {
                """
                // use moduleDir for consistent snapshot
                tmp_dir = "${moduleDir}/tests/temp"
                file(tmp_dir).mkdirs()

                input[0] = [
                    'genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb',
                    'genome_temp_dir':tmp_dir
                ]
                input[1] = [:]
                input[2] = "${projectDir}/tests/testdata/test_db.ini"
                """
            }
        }

        then {
            assert process.success

            // genome_meta does not change
            def tmp_dir = "${moduleDir}/tests/temp"
            assert process.out.get(0).get(0).get(0) == [
                'genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb',
                'genome_temp_dir':tmp_dir
            ]

            // cannot do snapshot match as cache dir path may vary 
            def file_content = path(process.out.get(0).get(0).get(1)).text
            assert file_content.contains("gff\t${tmp_dir}/sorted_genes.gff3.gz")
        }
    }
}