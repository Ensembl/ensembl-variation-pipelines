nextflow_process {

    name "Test process PROCESS_PLUGINS_CONFIG"
    script "../main.nf"
    process "PROCESS_PLUGINS_CONFIG"

    test("conf - empty") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = [:]
                input[2] = 110
                input[3] = 'NONE'
                """
            }
        }

        then {
            assert process.success

            assert path(process.out.get(0).get(0).get(1)).text == ''
        }
    }

    test("conf - empty 2") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = [conf:[:]]
                input[2] = 110
                input[3] = 'NONE'
                """
            }
        }

        then {
            assert process.success

            assert path(process.out.get(0).get(0).get(1)).text == ''
        }
    }

    test("conf - proper") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']
                input[1] = [conf:[[name:'CADD', keyed:true], [name:'SpliceAI', keyed:true]]]
                input[2] = 110
                input[3] = 'NONE'
                """
            }
        }

        then {
            assert process.success

            // genome_meta does not change
            assert process.out.get(0).get(0).get(0) == ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']
            
            // cannot do snapshot match as cache dir path may vary 
            def file_content = path(process.out.get(0).get(0).get(1)).text    
            assert file_content.contains("plugin\tCADD,snv=${projectDir}/modules/local/vep_config/plugins/tests/testdata/grch38/e113/vep/plugin_data/CADD_GRCh38_1.7_whole_genome_SNVs.tsv.gz,indels=${projectDir}/modules/local/vep_config/plugins/tests/testdata/grch38/e113/vep/plugin_data/CADD_GRCh38_1.7_InDels.tsv.gz")
            assert file_content.contains("plugin\tSpliceAI,snv=${projectDir}/modules/local/vep_config/plugins/tests/testdata/grch38/e113/vep/plugin_data/spliceai_scores.masked.snv.hg38.vcf.gz,indel=${projectDir}/modules/local/vep_config/plugins/tests/testdata/grch38/e113/vep/plugin_data/spliceai_scores.masked.indel.hg38.vcf.gz")
        }
    }
}