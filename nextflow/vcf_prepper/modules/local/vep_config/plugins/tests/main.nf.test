nextflow_process {

    name "Test process PROCESS_PLUGINS_CONFIG"
    script "../main.nf"
    process "PROCESS_PLUGINS_CONFIG"

    test("no conf") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = [:]
                input[2] = 110
                input[3] = 'NONE'
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("FileNotFoundError")
        }
    }

    test("conf - invalid") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb']
                input[1] = ['conf':"${moduleDir}/tests/testdata/non_existing.json"]
                input[2] = 110
                input[3] = 'NONE'
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("FileNotFoundError")
        }
    }

    test("conf - proper") {

        when {
            process {
                """
                input[0] = ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']
                input[1] = ['conf':"${moduleDir}/tests/testdata/test_conf.json"]
                input[2] = 110
                input[3] = 'NONE'
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()

            // genome_meta does not change
            assert process.out.get(0).get(0).get(0) == ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']

            // contains plugins
            assert path(process.out.get(0).get(0).get(1)).getText().contains("CADD")
            assert path(process.out.get(0).get(0).get(1)).getText().contains("SpliceAI")
        }
    }
}