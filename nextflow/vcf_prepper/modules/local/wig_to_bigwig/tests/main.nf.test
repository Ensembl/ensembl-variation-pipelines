nextflow_process {

    name "Test Process WIG_TO_BIGWIG"
    script "../main.nf"
    process "WIG_TO_BIGWIG"

    test("wig_to_bigwig") {

        when {
            process {
                """
				// use moduleDir for consistent snapshot
                tmp_dir = "${moduleDir}/tests/temp"
                file(tmp_dir).mkdirs()
                
				genome_meta = [:]
                genome_meta["source"] = "test"
				genome_meta["chrom_sizes_file"] = file("${moduleDir}/tests/testdata/homo_sapiens_GRCh38.chrom.sizes")
				genome_meta["genome_tracks_outdir"] = tmp_dir

				file_meta = [:]
                file_meta["source"] = "test"
                file_meta["multiple_source"] = false

				input[0] = tuple(genome_meta, file_meta, file("${moduleDir}/tests/testdata/short_variants.wig"))
                """
            }
        }

        then {
            assert process.success 
            assert snapshot(process.out).match()
            
            // the output is generated at the genome tracks dir
			// assert for single source we symlink the focus track
            def tmp_dir = "${moduleDir}/tests/temp"
			assert file(tmp_dir + "/variant-test-summary.bw").exists()
			assert file(tmp_dir + "/variant-summary.bw").exists()
			assert file(tmp_dir + "/variant-summary.bw").getCanonicalPath() == 
				(projectDir + "/modules/local/wig_to_bigwig/tests/temp/variant-test-summary.bw")
		}
    }
}
