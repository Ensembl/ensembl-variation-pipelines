nextflow_workflow {

    name "Test workflow GENERATE_VEP_CONFIG"
    script "../main.nf"
    workflow "GENERATE_VEP_CONFIG"

    test("generate_vep_config") {

        when {
            workflow {
                """
                input[0] = Channel.fromList([
                        ['genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 'species':'homo_sapiens', 'assembly':'GRCh38']
                    ])
                input[1] = ['file':"${projectDir}/modules/local/vep_config/fasta/tests/testdata/unmasked.fa.gz"]
                input[2] = ['file':"${projectDir}/modules/local/vep_config/gff/tests/testdata/genes.gff3.gz"]
                input[3] = ['active':false]
                input[4] = [force_overwrite:1, fork:2, vcf:1, spdi:1, variant_class:1, protein:1, transcript_version:1, gencode_promoter:1, offline:1]
                input[5] = [conf:[[name:'CADD', keyed:true], [name:'SpliceAI', keyed:true]]]
                input[6] = [:]
                input[7] = "${projectDir}/tests/testdata/test_db.ini"
                input[8] = 110
                input[9] = 'NONE'
                input[10] = 'NONE'
                input[11] = "${projectDir}/assets/population_data.json"
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()

            // genome_meta does not change
            assert workflow.out.get(0).get(0).get(0) == [
                'genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb', 
                'species':'homo_sapiens', 
                'assembly':'GRCh38'
            ]

            // cannot do snapshot match as cache dir path may vary 
            def file_content = path(workflow.out.get(0).get(0).get(1)).text
            assert file_content.contains("force_overwrite\t1")
            assert file_content.contains("fork\t2")
            assert file_content.contains("vcf\t1")
            assert file_content.contains("spdi\t1")
            assert file_content.contains("variant_class\t1")
            assert file_content.contains("protein\t1")
            assert file_content.contains("transcript_version\t1")
            assert file_content.contains("gencode_promoter\t1")
            assert file_content.contains("offline\t1")
            assert file_content.contains("fasta\t${projectDir}/modules/local/vep_config/fasta/tests/testdata/unmasked.fa.gz")
            assert file_content.contains("gff\t${projectDir}/modules/local/vep_config/gff/tests/testdata/genes.gff3.gz")
            assert file_content.contains("plugin\tCADD,snv=${projectDir}/modules/local/vep_config/plugins/tests/testdata/grch38/e113/vep/plugin_data/CADD_GRCh38_1.7_whole_genome_SNVs.tsv.gz,indels=${projectDir}/modules/local/vep_config/plugins/tests/testdata/grch38/e113/vep/plugin_data/CADD_GRCh38_1.7_InDels.tsv.gz")
            assert file_content.contains("plugin\tSpliceAI,snv=${projectDir}/modules/local/vep_config/plugins/tests/testdata/grch38/e113/vep/plugin_data/spliceai_scores.masked.snv.hg38.vcf.gz,indel=${projectDir}/modules/local/vep_config/plugins/tests/testdata/grch38/e113/vep/plugin_data/spliceai_scores.masked.indel.hg38.vcf.gz")
        }
    }
}