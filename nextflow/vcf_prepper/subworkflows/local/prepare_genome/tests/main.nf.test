nextflow_workflow {

    name "Test workflow PREPARE_GENOME"
    script "../main.nf"
    workflow "PREPARE_GENOME"

    test("prepare_genome") {

        when {
            workflow {
                """
                genome_meta = [
                    [
                        'genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb',
                        'genome':'homo_sapiens_grch38', 
                        'species':'homo_sapiens', 
                        'assembly':'GRCh38',
                        'genome_temp_dir':"${workDir}/path/to/temp/2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb",
                        'genome_api_outdir':"${workDir}/path/to/output/api/2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb",
                        'genome_tracks_outdir':"${workDir}/path/to/output/tracks/2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb",
                        'synonym_file':"${workDir}/path/to/temp/2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb/homo_sapiens_grch38.synonyms",
                        'chrom_sizes_file':"${workDir}/path/to/temp/2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb/homo_sapiens_grch38.chrom.sizes",
                    ]
                ]

                input[0] = Channel.fromList(genome_meta)
                input[1] = 110
                input[2] = "${projectDir}/tests/testdata/test_db.ini"
                """
            }
        }

        then {
            assert workflow.success

            // genome specific directories created
            assert file("${workDir}/path/to/temp/2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb").exists()
            assert file("${workDir}/path/to/output/api/2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb").exists()
            assert file("${workDir}/path/to/output/tracks/2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb").exists()

            // genome_meta does not change
            assert workflow.out.get(0).get(0).get(0) == [
                        'genome_uuid':'2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb',
                        'genome':'homo_sapiens_grch38', 
                        'species':'homo_sapiens', 
                        'assembly':'GRCh38',
                        'genome_temp_dir':"${workDir}/path/to/temp/2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb",
                        'genome_api_outdir':"${workDir}/path/to/output/api/2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb",
                        'genome_tracks_outdir':"${workDir}/path/to/output/tracks/2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb",
                        'synonym_file':"${workDir}/path/to/temp/2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb/homo_sapiens_grch38.synonyms",
                        'chrom_sizes_file':"${workDir}/path/to/temp/2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb/homo_sapiens_grch38.chrom.sizes",
                    ]

            assert file("${workDir}/path/to/temp/2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb/homo_sapiens_grch38.synonyms").exists()
            assert file("${workDir}/path/to/temp/2b5fb047-5992-4dfb-b2fa-1fb4e18d1abb/homo_sapiens_grch38.chrom.sizes").exists()
        }
    }
}