 nextflow_workflow {

    name "Test subworkflow PROCESS_INPUT"
    script "../main.nf"
    workflow "PROCESS_INPUT"

    test("run workflow") {

        when {
            workflow {
                """
                meta = [:]
                meta["file_type"] = "local"
                meta["source"] = "dbSNP"
                meta["synonym_file"] = "${projectDir}/tests/testdata/homo_sapiens_grch38.synonyms"
                meta["sources_meta_file"] = "${projectDir}/assets/sources_meta.json"
                
                file = "${projectDir}/assets/examples/test.vcf.gz"

                input[0] = tuple(meta, file)
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }
    }
}