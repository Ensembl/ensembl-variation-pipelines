nextflow_pipeline {

    name "Test workfloe VCF_PREPPER"
    script "../main.nf"
    tag "pipeline"

    test("skips - all") {

        when {
            params {
                repo_dir = "/Users/snhossain/ensembl-repos"
				input_config = "${projectDir}/tests/testdata/input_config.json"
				vep_config = "${projectDir}/tests/testdata/vep_config.json"
                skip_vep = 1
                skip_tracks = 1
                skip_stats = 1
            }
        }

        then {
            assert workflow.failed
            assert workflow.stdout.contains("Nothing to do...")
        }
    }

    test("skips - none") {

        when {
            params {
                repo_dir = "/Users/snhossain/ensembl-repos"
				output_dir = "/Users/snhossain/ensembl-repos"
				input_config = "${projectDir}/tests/testdata/input_config.json"
				vep_config = "${projectDir}/tests/testdata/vep_config.json"
				ini_file = "${projectDir}/tests/testdata/test_db.ini"
                bin_size = 10
            }
        }

        then {
            assert workflow.success
            assert workflow.stdout.contains("Nothing to do...")
        }
    }
}