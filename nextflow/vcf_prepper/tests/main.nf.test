nextflow_pipeline {

    name "Test workfloe VCF_PREPPER"
    script "../main.nf"
    tag "pipeline"

    test("all skips") {

        when {
            params {
                repo_dir = "/Users/snhossain/ensembl-repos"
                skip_vep = 1
                skip_tracks = 1
                skip_stats = 1
            }
        }

        then {
            assert workflow.failed
            assert workflow.stdout.contains("Nothing to do...")
        }
    }

    test("all skips") {

        when {
            params {
                repo_dir = "/Users/snhossain/ensembl-repos"
                skip_vep = 0
            }
        }

        then {
            assert workflow.success
            assert workflow.stdout.contains("Nothing to do...")
        }
    }
}