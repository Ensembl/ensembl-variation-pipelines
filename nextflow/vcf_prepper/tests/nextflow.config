singularity.enabled = false
        
process{
    withName: SPLIT_VCF_CHR {
        memory = 10.MB
    }

    withName: runVEPonVCF {
        cpus = 1
        memory = 200.MB
    }
}

profiles {
    github {
        docker.enabled = true
        params.repo_dir = "${projectDir}/repos"

        process{
            withLabel: vep {
                container = 'docker://ensemblorg/ensembl-vep'
            }
        }
    }
    local {
        params.repo_dir = "/Users/snhossain/ensembl-repos"
    }
}